# ─── Wiki.js Self-Hosted Configuration ───────────────────────────
# Copy to .env and fill in your values
#   cp .env.example .env

# ─── Domain ────────────────────────────────────────────────────
WIKI_DOMAIN=wiki.yourcompany.com
WIKI_PORT=3000

# ─── PostgreSQL ──────────────────────────────────────────────────
DB_POSTGRES_HOST=db
DB_POSTGRES_PORT=5432
DB_POSTGRES_DB=wiki
DB_POSTGRES_USER=wikijs
DB_POSTGRES_PASS=change-this-to-a-strong-password

# ─── PostgreSQL Root (for initial setup, optional) ───────────────
DB_POSTGRES_ROOT_USER=postgres
DB_POSTGRES_ROOT_PASS=change-this-too

# ─── Wiki.js Admin Account (first-run auto-creation) ────────────
WIKI_ADMIN_EMAIL=admin@yourcompany.com

# ─── SSL (Certbot / Let's Encrypt) ──────────────────────────────
LETSENCRYPT_EMAIL=admin@yourcompany.com

# ─── GitHub Sync (for bi-directional sync) ─────────────────────
# Create a GitHub PAT: https://github.com/settings/tokens
# Scopes needed: repo (full control) or public_repo for public repos
GITHUB_SYNC_REPO=vanchasrujankumar/engineering-docs
GITHUB_SYNC_BRANCH=main
GITHUB_SYNC_TOKEN=ghp_your-personal-access-token-here
